# 复制为 .deploy.env(被 .gitignore),然后按项目实际情况填写。
# scripts/deploy.sh 会自动加载此文件。

# ---- 基础 SSH ----
DEPLOY_HOST=your.server.example.com
DEPLOY_USER=root
DEPLOY_APP_USER=deploy
DEPLOY_PATH=/var/www/your-project

# ---- 分支 ----
DEPLOY_BRANCH_TEST=test
DEPLOY_BRANCH_PROD=master

# ---- PM2 应用名 ----
PM2_APP_TEST=your-project-test
PM2_APP_PROD=your-project-prod

# ---- 健康检查 ----
LOCAL_HEALTH_PORT_TEST=3002
LOCAL_HEALTH_PORT_PROD=3001
PUBLIC_HEALTH_URL_TEST=https://test.example.com/api/health
PUBLIC_HEALTH_URL_PROD=https://example.com/api/health
