# -------- APP --------
# development | test | production
APP_ENV=development
PORT=3000
# 1 = 全局关缓存(本地联调顺手打开)
DISABLE_HTTP_CACHE=0
# API 耗时埋点采样率(0.0 - 1.0),默认 0.1
API_TIMING_SAMPLE_RATE=0.1

# -------- Auth(JWT)--------
# 生产环境必填。本地不填会用 dev-secret-do-not-use-in-production。
AUTH_JWT_SECRET=

# 生产回归测试用:请求带 x-user-id + x-test-key 时可伪装身份。
AUTH_TEST_KEY=

# CORS 白名单(逗号分隔)。空 + 生产环境 = 只允许同源。
CORS_ALLOWED_ORIGINS=

# -------- MySQL --------
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# -------- Tencent COS --------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
# 可选:自定义 CDN 域。空则用 {bucket}.cos.{region}.myqcloud.com。
COS_PUBLIC_BASE_URL=
COS_ENDPOINT=

# -------- Tencent IM --------
IM_SDK_APP_ID=
IM_SECRET_KEY=
IM_ADMIN_USER=administrator
IM_API_BASE_URL=https://console.tim.qq.com
# dev | prod,决定 imUserId 前缀,空时跟随 APP_ENV。
IM_ENV=
